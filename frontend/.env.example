# Frontend (Vite). Sem estas variáveis, o app roda em "modo mock"
# (dados locais no navegador, sem backend).

# Supabase — persistência real (multiusuário). Vazio = modo mock.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# Base do backend que expõe /api/v1/* (faturamento Cakto, clone Tynk).
# Em desenvolvimento: deixe vazio — o app usa a ponte local em http://localhost:4000
# (ver ../server/README.md).
# Em produção: a URL do backend, ex. https://api.seuapp.com
VITE_API_BASE=""
