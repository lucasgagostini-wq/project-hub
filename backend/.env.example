# Banco
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gestao_ofertas?schema=public"

# Auth
JWT_SECRET="troque-isto-em-producao"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=4000
CORS_ORIGIN="http://localhost:5173"

# ---- Integrações (preencher no painel do host; NUNCA commitar valores) ----
# UTMFy — só ENTRADA: a Cakto envia as vendas para o UTMfy (POST /api-credentials/orders).
# Não há API pública de leitura de gasto no UTMfy.
UTMFY_API_BASE="https://api.utmify.com.br"
UTMFY_API_TOKEN=""

# Cakto — autenticação OAuth2 (client_id + client_secret). Gera o par em:
#   painel Cakto > Integrações > Cakto API > Criar Chave de API
# Fluxo: POST /public_api/token/ (form) -> access_token Bearer -> GET /public_api/orders/
CAKTO_API_BASE="https://api.cakto.com.br"
CAKTO_CLIENT_ID=""
CAKTO_CLIENT_SECRET=""
CAKTO_WEBHOOK_SECRET=""

# Tynk Pages — clonagem de página/oferta. Key Bearer (prefixo ep_).
#   base: https://pages.tynk.ai | doc: https://pages.tynk.ai/api/docs
TYNK_API_BASE="https://pages.tynk.ai"
TYNK_API_KEY=""
