// =====================================================================
//  Modelo de dados — Gestão de Ofertas
//  Toda a estrutura está aqui. O dev roda `prisma migrate dev` e tem o
//  banco pronto. Regra de acesso do produto: todo usuário autenticado
//  vê e edita tudo — por isso NÃO há tabela de permissões por recurso.
//  A identidade serve sobretudo para o RASTREAMENTO (AuditLog).
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------- Enums -----------------------------------
enum Role {
  FOUNDER
  TRAFEGO
  COPY
  DESIGN
  MEMBER
}

enum SalesChannel {
  META_ADS
  GOOGLE_ADS
  SMS
  PROSPECTING
}

enum IntegrationProvider {
  UTMFY
  CAKTO
}

enum IntegrationStatus {
  DISCONNECTED
  CONNECTED
  ERROR
}

enum MetricSource {
  UTMFY
  CAKTO
  MANUAL
}

// --------------------------- Usuário ---------------------------------
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  photoUrl     String?
  role         Role     @default(MEMBER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdProjects Project[]            @relation("ProjectCreatedBy")
  assignedTasks   Task[]               @relation("TaskAssignee")
  createdTasks    Task[]               @relation("TaskCreatedBy")
  meetings        MeetingParticipant[]
  offerActions    OfferAction[]        @relation("ActionResponsible")
  auditLogs       AuditLog[]
}

// --------------------------- Projeto ---------------------------------
model Project {
  id        String   @id @default(cuid())
  name      String
  niche     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  createdBy   User?   @relation("ProjectCreatedBy", fields: [createdById], references: [id])

  // Gestão de oferta (1-1 e 1-N)
  offer        Offer?
  persona      Persona?
  links        OfferLink[]
  creatives    Creative[]
  actions      OfferAction[]
  metrics      MetricSnapshot[]
  integrations IntegrationConfig[]
  tasks        Task[]

  @@index([active])
}

// Estruturação da oferta (1-1 com Project)
model Offer {
  id          String        @id @default(cuid())
  projectId   String        @unique
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  description String?       // "qual é a oferta"
  audience    String?       // público-alvo
  ageRange    String?       // idade do público (ex.: "28-45")
  mainChannel SalesChannel? // maior veículo de venda
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// Links de landing page / site / checkout
model OfferLink {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String   // "Landing page" | "Site" | "Checkout" | ...
  url       String
  createdAt DateTime @default(now())

  @@index([projectId])
}

// Persona mapeada (1-1 com Project)
model Persona {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  who       String?  // quem é (ex.: "Renata, 36")
  pain      String?  // dor principal
  desire    String?  // desejo
  objection String?  // principal objeção
  channel   String?  // onde está / canal
  updatedAt DateTime @updatedAt
}

// Criativos (para o "top 3 que mais vendem")
model Creative {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  sales     Int      @default(0)
  spend     Decimal? @db.Decimal(12, 2)
  revenue   Decimal? @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  @@index([projectId])
}

// Snapshot diário de métricas — alimenta a linha do tempo / gráfico.
// Origem: integrações (UTMFy, Cakto, gerenciador) ou lançamento manual.
model MetricSnapshot {
  id        String       @id @default(cuid())
  projectId String
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  date      DateTime     @db.Date
  revenue   Decimal      @default(0) @db.Decimal(12, 2) // faturamento do dia
  netProfit Decimal      @default(0) @db.Decimal(12, 2) // lucro líquido
  adSpend   Decimal      @default(0) @db.Decimal(12, 2) // gasto com anúncios
  source    MetricSource @default(MANUAL)
  createdAt DateTime     @default(now())

  @@unique([projectId, date, source])
  @@index([projectId, date])
}

// Ação / mudança na oferta — vira ponto no calendário da oferta.
// Quando tem data + responsável, deve aparecer no calendário pessoal dele.
model OfferAction {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  date          DateTime
  label         String   // "Subiu novo criativo", "Aumentou verba 30%"...
  responsibleId String?
  responsible   User?    @relation("ActionResponsible", fields: [responsibleId], references: [id])
  createdAt     DateTime @default(now())

  @@index([projectId])
  @@index([responsibleId])
}

// --------------------------- Tarefas ---------------------------------
model Task {
  id          String    @id @default(cuid())
  title       String
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assigneeId  String?
  assignee    User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  dueDate     DateTime?
  done        Boolean   @default(false)
  createdById String?
  createdBy   User?     @relation("TaskCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([assigneeId])
  @@index([projectId])
}

// --------------------------- Reuniões --------------------------------
model Meeting {
  id           String               @id @default(cuid())
  title        String
  date         DateTime
  time         String?              // "10:00"
  createdAt    DateTime             @default(now())
  participants MeetingParticipant[]
}

model MeetingParticipant {
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([meetingId, userId])
}

// --------------------------- Integrações -----------------------------
// Liga um projeto a uma conta externa. NÃO guarde segredos crus aqui em
// produção — use um cofre (KMS/Secrets Manager) e referencie por id.
model IntegrationConfig {
  id                String              @id @default(cuid())
  projectId         String
  project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  provider          IntegrationProvider
  externalAccountId String?             // id da conta de anúncios / produto
  credentialRef     String?             // referência ao segredo no cofre
  status            IntegrationStatus   @default(DISCONNECTED)
  lastSyncedAt      DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([projectId, provider])
}

// --------------------------- Rastreamento ----------------------------
// "Tudo que for feito tem rastreamento do usuário que mexeu e editou."
// Escrito automaticamente em toda mutação (ver middleware/audit.ts).
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String   // CREATE | UPDATE | DELETE | LOGIN ...
  entityType String   // "Project" | "Persona" | "Offer" ...
  entityId   String
  projectId  String?  // para filtrar o feed por projeto
  before     Json?    // estado anterior (em UPDATE/DELETE)
  after      Json?    // estado novo (em CREATE/UPDATE)
  createdAt  DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([userId, createdAt])
  @@index([entityType, entityId])
}
